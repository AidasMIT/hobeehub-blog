---
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a href="/" class="logo">
			<span class="logo-text">🐝 HobeeHub</span>
			<span class="logo-sub">Blog</span>
		</a>
		<div class="internal-links">
			<HeaderLink href="/">Pradžia</HeaderLink>
			<HeaderLink href="/blog">Straipsniai</HeaderLink>
			<HeaderLink href="https://hobeehub.com">HobeeHub ↗</HeaderLink>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 2rem;
		background: rgba(255,255,255,0.9);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
		border-bottom: 1px solid rgba(245,158,11,0.15);
		position: sticky;
		top: 0;
		z-index: 100;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 720px;
		margin: 0 auto;
		height: 64px;
	}
	.logo {
		text-decoration: none;
		display: flex;
		align-items: center;
		gap: 0.4rem;
	}
	.logo-text {
		font-family: 'Baloo 2', sans-serif;
		font-size: 1.25rem;
		font-weight: 800;
		color: rgb(var(--black));
		letter-spacing: -0.01em;
	}
	.logo-sub {
		font-size: 0.75rem;
		font-weight: 600;
		color: var(--accent);
		background: var(--accent-light);
		padding: 0.1em 0.5em;
		border-radius: 999px;
		margin-top: 2px;
	}
	.internal-links { display: flex; gap: 2px; }
	nav a {
		padding: 0.5em 0.875em;
		color: rgb(var(--gray));
		text-decoration: none;
		font-size: 0.875em;
		font-weight: 500;
		border-radius: 10px;
		transition: all 0.15s;
	}
	nav a:hover {
		color: rgb(var(--black));
		background: rgb(var(--gray-light));
	}
	nav a.active {
		color: var(--accent-dark);
		background: var(--accent-light);
	}
	@media (max-width: 720px) {
		header { padding: 0 1rem; }
		.logo-sub { display: none; }
	}
</style>

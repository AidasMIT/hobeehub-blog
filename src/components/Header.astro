---
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a href="/" class="logo">
			<img src="/hobeehub-logo.svg" alt="hobeehub" class="logo-img" />
		</a>
		<div class="internal-links">
			<HeaderLink href="/">Pradžia</HeaderLink>
			<HeaderLink href="/blog">Straipsniai</HeaderLink>
			<HeaderLink href="https://hobeehub.com">hobeehub ↗</HeaderLink>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 2rem;
		background: rgba(255,255,255,0.9);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
		border-bottom: 1px solid rgba(245,158,11,0.15);
		position: sticky;
		top: 0;
		z-index: 100;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 720px;
		margin: 0 auto;
		height: 64px;
	}
	.logo { text-decoration: none; display: flex; align-items: center; }
	.logo-img { height: 32px; width: auto; border-radius: 0; }
	.internal-links { display: flex; gap: 2px; }
	nav a {
		padding: 0.5em 0.875em;
		color: rgb(var(--gray));
		text-decoration: none;
		font-size: 0.875em;
		font-weight: 500;
		border-radius: 10px;
		transition: all 0.15s;
	}
	nav a:hover { color: rgb(var(--black)); background: rgb(var(--gray-light)); }
	nav a.active { color: var(--accent-dark); background: var(--accent-light); }
	@media (max-width: 720px) { header { padding: 0 1rem; } }
</style>

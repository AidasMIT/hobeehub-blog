---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="lt">
	<head>
		<BaseHead title={`Visi straipsniai — ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			.page-header {
				padding: 3em 0 2em;
				border-bottom: 1px solid rgba(var(--gray), 0.15);
				margin-bottom: 2em;
			}
			.page-badge {
				display: inline-block;
				font-size: 0.78em;
				font-weight: 600;
				letter-spacing: 0.1em;
				text-transform: uppercase;
				color: var(--accent-dark);
				background: var(--accent-light);
				border: 1px solid rgba(245,158,11,0.3);
				padding: 5px 14px;
				border-radius: 100px;
				margin-bottom: 1em;
			}
			.page-title {
				font-size: 2em;
				margin-bottom: 0.3em;
				color: rgb(var(--black));
			}
			.page-desc {
				color: rgb(var(--gray));
				font-size: 1em;
				margin: 0;
			}
			.posts { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.75em; }
			.posts li { }
			.post-card {
				display: block;
				text-decoration: none;
				padding: 1.5em 1.75em;
				background: #fafafa;
				border: 1px solid rgba(var(--gray), 0.15);
				border-radius: 14px;
				transition: all 0.18s ease;
			}
			.post-card:hover {
				background: #fff;
				border-color: rgba(245,158,11,0.35);
				box-shadow: 0 4px 16px rgba(0,0,0,0.06);
				transform: translateY(-2px);
				text-decoration: none;
			}
			.post-title {
				font-family: 'Lora', Georgia, serif;
				font-size: 1.15em;
				font-weight: 700;
				color: rgb(var(--black));
				margin: 0 0 0.4em;
				line-height: 1.4;
				transition: color 0.15s;
			}
			.post-card:hover .post-title { color: var(--accent-dark); }
			.post-desc {
				color: rgb(var(--gray));
				font-size: 0.88em;
				margin: 0 0 0.6em;
				line-height: 1.55;
			}
			.post-meta {
				color: rgb(var(--gray));
				font-size: 0.75em;
				font-weight: 500;
				opacity: 0.75;
			}
			@media (max-width: 720px) {
				.page-title { font-size: 1.6em; }
				.post-card { padding: 1.25em; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="page-header">
				<span class="page-badge">✦ Tinklaraštis</span>
				<h1 class="page-title">Visi straipsniai</h1>
				<p class="page-desc">Praktiniai vadovai būrelių organizatoriams.</p>
			</div>
			<ul class="posts">
				{posts.map((post) => (
					<li>
						<a href={`/blog/${post.id}/`} class="post-card">
							<h2 class="post-title">{post.data.title}</h2>
							{post.data.description && <p class="post-desc">{post.data.description}</p>}
							<span class="post-meta"><FormattedDate date={post.data.pubDate} /></span>
						</a>
					</li>
				))}
			</ul>
		</main>
		<Footer />
	</body>
</html>

---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
).slice(0, 10);
---

<!doctype html>
<html lang="lt">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero {
				padding: 4em 0 3em;
			}
			.hero-badge {
				display: inline-flex;
				align-items: center;
				gap: 6px;
				font-size: 0.78em;
				font-weight: 600;
				letter-spacing: 0.1em;
				text-transform: uppercase;
				color: var(--accent-dark);
				background: var(--accent-light);
				border: 1px solid rgba(245,158,11,0.3);
				padding: 5px 14px;
				border-radius: 100px;
				margin-bottom: 1.25em;
			}
			.hero h1 {
				font-size: 2.6em;
				margin-bottom: 0.5em;
				color: rgb(15, 23, 42);
				line-height: 1.15;
			}
			.hero h1 span { color: var(--accent); }
			.hero-desc {
				color: rgb(var(--gray));
				font-size: 1.1em;
				max-width: 560px;
				line-height: 1.75;
				margin-bottom: 0;
			}

			.divider {
				height: 1px;
				background: rgba(var(--gray), 0.15);
				margin: 2.5em 0;
			}

			.section-title {
				font-family: 'Lora', Georgia, serif;
				font-size: 1.05em;
				font-weight: 700;
				color: rgb(var(--black));
				margin-bottom: 1.25em;
			}

			.posts { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.75em; }

			.post-card {
				display: block;
				text-decoration: none;
				padding: 1.5em 1.75em;
				background: #fafafa;
				border: 1px solid rgba(var(--gray), 0.15);
				border-radius: 14px;
				transition: all 0.18s ease;
			}
			.post-card:hover {
				background: #fff;
				border-color: rgba(245,158,11,0.35);
				box-shadow: 0 4px 16px rgba(0,0,0,0.06);
				transform: translateY(-2px);
				text-decoration: none;
			}
			.post-title {
				font-family: 'Lora', Georgia, serif;
				font-size: 1.15em;
				font-weight: 700;
				color: rgb(var(--black));
				margin: 0 0 0.4em;
				line-height: 1.4;
				transition: color 0.15s;
			}
			.post-card:hover .post-title { color: var(--accent-dark); }
			.post-desc {
				color: rgb(var(--gray));
				font-size: 0.88em;
				margin: 0 0 0.6em;
				line-height: 1.55;
			}
			.post-meta {
				color: rgb(var(--gray));
				font-size: 0.75em;
				font-weight: 500;
				opacity: 0.75;
			}

			@media (max-width: 720px) {
				.hero { padding: 2.5em 0 2em; }
				.hero h1 { font-size: 1.9em; }
				.hero-desc { font-size: 1em; }
				.post-card { padding: 1.25em; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<span class="hero-badge">✦ Tinklaraštis</span>
				<h1>Valdyk būrelį <span>protingiau</span></h1>
				<p class="hero-desc">Praktiniai straipsniai būrelių organizatoriams: skaitmeniniai įrankiai, augimo taktikos, administravimas ir daugiau.</p>
			</section>

			<div class="divider"></div>

			<p class="section-title">Naujausi straipsniai</p>
			<ul class="posts">
				{posts.map((post) => (
					<li>
						<a href={`/blog/${post.id}/`} class="post-card">
							<h2 class="post-title">{post.data.title}</h2>
							{post.data.description && <p class="post-desc">{post.data.description}</p>}
							<span class="post-meta"><FormattedDate date={post.data.pubDate} /></span>
						</a>
					</li>
				))}
			</ul>
		</main>
		<Footer />
	</body>
</html>
